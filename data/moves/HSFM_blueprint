export class SlotResolver {
  static resolve(holdType, direction, button, isSpecialActive) {
    const map = SLOT_MAPS[holdType];
    if (!map) return null;

    // Finisher override: only from strong holds, only with Special active
    if (isSpecialActive && button === 'controlStick' && holdType.includes('Strong')) {
      const finisherKey = 'controlStick';
      if (map[finisherKey]) return map[finisherKey];
    }

    const key = `${direction}+${button}`;
    return map[key] || null;
  }
}
