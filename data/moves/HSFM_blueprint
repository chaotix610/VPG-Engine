### Input Snapshot

```javascript
// ─────────────────────────────────────────────
// InputSnapshot.js
// ─────────────────────────────────────────────

export class InputSnapshot {
  constructor() {
    this.buttons = {};          // { A: false, B: false, R: false, L: false, ... }
    this.holdDurations = {};    // { A: 0, B: 0, ... } in frames
    this.dpad = { x: 0, y: 0 };
    this.controlStick = { x: 0, y: 0 };
    this.previousButtons = {};
  }

  justPressed(button) {
    return this.buttons[button] && !this.previousButtons[button];
  }

  isHeld(button) {
    return this.buttons[button];
  }

  holdFrames(button) {
    return this.holdDurations[button] || 0;
  }

  isStrongGrapple() {
    return this.holdDurations['A'] >= STRONG_GRAPPLE_HOLD_THRESHOLD;
  }

  getDirectionalButton() {
    // Returns { direction, button } if a direction+button combo was input this frame
    const dir = this.resolveDirection();
    for (const btn of ['A', 'B']) {
      if (this.justPressed(btn)) {
        return { direction: dir, button: btn };
      }
    }
    if (this.controlStickMoved()) {
      return { direction: 'neutral', button: 'controlStick' };
    }
    return null;
  }

  resolveDirection() {
    const { x, y } = this.dpad;
    if (x !== 0 && y === 0) return 'leftRight';
    if (x === 0 && y > 0)  return 'up';
    if (x === 0 && y < 0)  return 'down';
    if (x !== 0 || y !== 0) return 'anyDirection';
    return 'neutral';
  }

  controlStickMoved() {
    return Math.abs(this.controlStick.x) > 0.5 ||
           Math.abs(this.controlStick.y) > 0.5;
  }

  hasReversalInput() {
    return this.justPressed('R') ||
           this.justPressed('A') ||
           this.justPressed('B') ||
           this.justPressed('L');
  }
}
