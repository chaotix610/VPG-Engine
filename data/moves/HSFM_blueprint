### HFSM Base Classes

```javascript
// ─────────────────────────────────────────────
// State.js — Base state class
// ─────────────────────────────────────────────

export class State {
  constructor(id, parent = null) {
    this.id = id;
    this.parent = parent;
    this.children = new Map();
    this.activeChild = null;
    this.frameCounter = 0;
  }

  addChild(state) {
    state.parent = this;
    this.children.set(state.id, state);
    return this;
  }

  canEnter(context) { return true; }
  canExit() { return true; }

  onEnter(context) {
    this.frameCounter = 0;
  }

  onExit() {
    if (this.activeChild) {
      this.activeChild.onExit();
      this.activeChild = null;
    }
  }

  onUpdate(context) {
    this.frameCounter++;
    if (this.activeChild) {
      this.activeChild.onUpdate(context);
    }
  }

  transitionTo(childId, context) {
    const next = this.children.get(childId);
    if (!next) throw new Error(`No child state: ${childId}`);
    if (!next.canEnter(context)) return false;

    if (this.activeChild) {
      if (!this.activeChild.canExit()) return false;
      this.activeChild.onExit();
    }

    this.activeChild = next;
    this.activeChild.onEnter(context);
    return true;
  }

  getActiveLeaf() {
    if (!this.activeChild) return this;
    return this.activeChild.getActiveLeaf();
  }
}
```

