// ─────────────────────────────────────────────
// GrappleHoldState.js
// ─────────────────────────────────────────────

import { State } from './State.js';
import { SlotResolver } from '../moves/SlotResolver.js';

export class GrappleHoldState extends State {
  constructor(id) {
    super(id);
    this.holdType = null;     // 'frontWeak', 'frontStrong', 'backWeak', 'backStrong', ...
    this.holdTimer = 0;
    this.maxHoldFrames = 0;
    this.switchCount = 0;
    this.maxSwitches = 3;
  }

  canEnter(context) {
    return context.interaction &&
           context.interaction.state === 'GrappleLock' &&
           !context.interaction.moveExecutionLock;
  }

  onEnter(context) {
    super.onEnter(context);
    this.holdType = context.interaction.holdType;
    this.holdTimer = 0;
    this.switchCount = 0;

    // Hold window varies by grapple strength
    this.maxHoldFrames = this.holdType.includes('Strong') ? 45 : 30;
  }

  onUpdate(context) {
    super.onUpdate(context);
    this.holdTimer++;

    const { input, interaction, spiritMeter, events } = context;

    // Timeout: grapple breaks
    if (this.holdTimer >= this.maxHoldFrames) {
      events.emit('HOLD_TIMEOUT', { interaction });
      return;
    }

    // L-button: position switch (front ↔ back)
    if (input.justPressed('L') && this.switchCount < this.maxSwitches) {
      this.switchCount++;
      this.holdType = this.flipPosition(this.holdType);
      interaction.holdType = this.holdType;
      return;
    }

    // R-button: break grapple
    if (input.justPressed('R')) {
      events.emit('HOLD_BROKEN', { interaction });
      return;
    }

    // Directional + button input: resolve move slot
    const moveInput = input.getDirectionalButton();
    if (moveInput) {
      const slotId = SlotResolver.resolve(
        this.holdType,
        moveInput.direction,
        moveInput.button,
        spiritMeter.isSpecialActive()
      );

      if (slotId) {
        events.emit('SLOT_RESOLVED', {
          slotId,
          interaction,
          attackerId: context.characterId
        });
      }
    }
  }

  flipPosition(holdType) {
    if (holdType.startsWith('front')) return holdType.replace('front', 'back');
    if (holdType.startsWith('back')) return holdType.replace('back', 'front');
    return holdType;
  }

  canExit() { return true; }

  onExit() {
    super.onExit();
    this.holdType = null;
    this.holdTimer = 0;
    this.switchCount = 0;
  }
}
