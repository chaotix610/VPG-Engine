import { State } from './State.js';

export class HFSMController {
  constructor(characterId) {
    this.characterId = characterId;

    // Exclusive regions
    this.actionRegion = this.buildActionTree();
    this.interactionRegion = new InteractionRegion();

    // Orthogonal regions
    this.spiritMeter = new SpiritMeterRegion();
    this.bodyDamage = new BodyDamageRegion();

    // Event bus for cross-region communication
    this.events = new EventBus();
    this.wireEvents();
  }

  buildActionTree() {
    const root = new State('Action');

    root.addChild(new NeutralState('Neutral'));
    root.addChild(new StrikingState('Striking'));
    root.addChild(new GrappleInitiationState('GrappleInitiation'));
    root.addChild(new GrappleHoldState('GrappleHold'));
    root.addChild(new ExecutingMoveState('ExecutingMove'));
    root.addChild(new IrishWhipState('IrishWhip'));
    root.addChild(new DownedState('Downed'));
    root.addChild(new RisingState('Rising'));
    root.addChild(new StunnedState('Stunned'));
    root.addChild(new AerialState('Aerial'));
    root.addChild(new PinAttemptState('PinAttempt'));
    root.addChild(new SubmissionAttemptState('SubmissionAttempt'));
    root.addChild(new GroundInteractionState('GroundInteraction'));
    root.addChild(new ReversalState('Reversal'));
    root.addChild(new TauntState('Taunt'));
    root.addChild(new RingsideState('Ringside'));
    root.addChild(new DoubleTeamState('DoubleTeam'));
    root.addChild(new EntranceState('Entrance'));

    root.transitionTo('Neutral', {});
    return root;
  }

  wireEvents() {
    // Action → SpiritMeter
    this.events.on('MOVE_HIT', (e) => this.spiritMeter.onMoveHit(e));
    this.events.on('MOVE_RECEIVED', (e) => this.spiritMeter.onMoveReceived(e));
    this.events.on('TAUNT_COMPLETE', () => this.spiritMeter.onTaunt());
    this.events.on('FINISHER_EXECUTED', () => this.spiritMeter.onFinisherUsed());

    // Action → BodyDamage
    this.events.on('DAMAGE_DEALT', (e) => this.bodyDamage.applyDamage(e));

    // BodyDamage → Action (threshold events)
    this.bodyDamage.onThreshold = (event) => this.events.emit(event.type, event);
  }

  update(inputSnapshot) {
    const context = {
      characterId: this.characterId,
      input: inputSnapshot,
      spiritMeter: this.spiritMeter,
      bodyDamage: this.bodyDamage,
      interaction: this.interactionRegion,
      events: this.events,
      actionState: this.actionRegion.getActiveLeaf()
    };

    // Orthogonal regions tick independently
    this.spiritMeter.update(context);
    this.bodyDamage.update(context);

    // Exclusive regions
    this.actionRegion.onUpdate(context);
    this.interactionRegion.update(context);
  }
}
