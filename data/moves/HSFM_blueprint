  constructor(scene, animationLibrary) {
    this.scene = scene;
    this.library = animationLibrary; // Maps (stateId, moveId) → animation clip name
  }

  syncCharacter(charId, controller) {
    const leaf = controller.actionRegion.getActiveLeaf();
    const stateId = leaf.id;
    const frameCounter = leaf.frameCounter;
    const moveId = leaf.currentMoveId || null;

    const clipName = this.library.resolve(stateId, moveId);
    const mesh = this.scene.getMeshByName(charId);

    if (!mesh || !clipName) return;

    // Set animation to exact frame — no independent playback
    const anim = mesh.getAnimationByName(clipName);
    if (anim) {
      anim.goToFrame(frameCounter);
    }
  }
}
```

